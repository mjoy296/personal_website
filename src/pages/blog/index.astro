---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { base } from '../../lib/url';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — Marissa Joy" description="Writing by Marissa Joy">
  <h1 class="text-3xl font-bold mb-8">Blog</h1>
  <ul class="divide-y divide-blue-100">
    {sorted.map(post => (
      <li class="py-5">
        <a href={`${base}blog/${post.id}/`} class="group">
          <h2 class="font-semibold text-lg group-hover:text-blue-600 transition-colors">{post.data.title}</h2>
          <p class="text-sm text-blue-900/70 mt-1">{post.data.description}</p>
          <div class="flex items-center gap-3 mt-2">
            <time class="text-xs text-blue-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.tags.length > 0 && (
              <ul class="flex gap-2">
                {post.data.tags.map(tag => (
                  <li class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">{tag}</li>
                ))}
              </ul>
            )}
          </div>
        </a>
      </li>
    ))}
  </ul>
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .slice(0, 3);
---

<Layout title="Marissa Joy">
  <section class="mb-16">
    <h1 class="text-4xl font-bold mb-4">Hi, I'm Marissa Joy</h1>
    <p class="text-lg text-blue-900/70 mb-6">
      Software engineer and writer. I build things and occasionally write about them.
    </p>
    <div class="flex gap-4">
      <a href={`${base}projects/`} class="bg-blue-700 text-white px-4 py-2 rounded text-sm hover:bg-blue-800 transition-colors">
        View projects
      </a>
      <a href={`${base}blog/`} class="border border-blue-300 px-4 py-2 rounded text-sm hover:bg-blue-50 transition-colors">
        Read blog
      </a>
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="mb-16">
      <h2 class="text-xl font-semibold mb-6">Featured projects</h2>
      <ul class="grid gap-4 sm:grid-cols-2">
        {featuredProjects.map(project => (
          <li>
            <a href={`${base}projects/${project.id}/`} class="group block border border-blue-200 rounded-lg p-4 hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
              <h3 class="font-medium mb-1 group-hover:text-blue-600 transition-colors">{project.data.title}</h3>
              <p class="text-sm text-blue-900/70 mb-3">{project.data.description}</p>
              <div class="flex gap-2 flex-wrap">
                {project.data.tags.map(tag => (
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            </a>
          </li>
        ))}
      </ul>
      <a href={`${base}projects/`} class="inline-block mt-4 text-sm text-blue-500 hover:text-blue-800 transition-colors">
        All projects →
      </a>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section>
      <h2 class="text-xl font-semibold mb-6">Recent posts</h2>
      <ul class="divide-y divide-blue-100">
        {recentPosts.map(post => (
          <li class="py-4">
            <a href={`${base}blog/${post.id}/`} class="group">
              <h3 class="font-medium group-hover:text-blue-600 transition-colors">{post.data.title}</h3>
              <p class="text-sm text-blue-900/70 mt-1">{post.data.description}</p>
              <time class="text-xs text-blue-400 mt-1 block">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
      <a href={`${base}blog/`} class="inline-block mt-4 text-sm text-blue-500 hover:text-blue-800 transition-colors">
        All posts →
      </a>
    </section>
  )}
</Layout>

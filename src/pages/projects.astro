---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const projects = await getCollection('projects');
---

<Layout title="Projects — Marissa Joy" description="Projects by Marissa Joy">
  <h1 class="text-3xl font-bold mb-8">Projects</h1>
  <ul class="grid gap-6 sm:grid-cols-2">
    {projects.map(project => (
      <li class="border border-gray-200 rounded-lg p-5 flex flex-col">
        <h2 class="font-semibold text-lg mb-2">{project.data.title}</h2>
        <p class="text-sm text-gray-600 flex-1 mb-4">{project.data.description}</p>
        <div class="flex gap-2 flex-wrap mb-4">
          {project.data.tags.map(tag => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
        <div class="flex gap-3 text-sm">
          {project.data.url && (
            <a href={project.data.url} class="text-gray-700 hover:text-gray-900 transition-colors" target="_blank" rel="noopener noreferrer">
              Live site ↗
            </a>
          )}
          {project.data.repo && (
            <a href={project.data.repo} class="text-gray-700 hover:text-gray-900 transition-colors" target="_blank" rel="noopener noreferrer">
              Source ↗
            </a>
          )}
        </div>
      </li>
    ))}
  </ul>
</Layout>

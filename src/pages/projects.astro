---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const projects = await getCollection('projects');
---

<Layout title="Projects — Marissa Joy" description="Projects by Marissa Joy">
  <h1 class="text-3xl font-bold mb-8">Projects</h1>
  <ul class="grid gap-6 sm:grid-cols-2">
    {projects.map(project => (
      <li>
        <a href={`${base}projects/${project.id}/`} class="group block border border-blue-200 rounded-lg p-5 flex flex-col h-full hover:border-blue-400 hover:bg-blue-50/50 transition-colors">
          <h2 class="font-semibold text-lg mb-2 group-hover:text-blue-600 transition-colors">{project.data.title}</h2>
          <p class="text-sm text-blue-900/70 flex-1 mb-4">{project.data.description}</p>
          <div class="flex gap-2 flex-wrap mb-4">
            {project.data.tags.map(tag => (
              <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
          <span class="text-sm text-blue-500 group-hover:text-blue-700 transition-colors">View →</span>
        </a>
      </li>
    ))}
  </ul>
</Layout>

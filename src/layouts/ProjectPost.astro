---
import Layout from './Layout.astro';
import { base } from '../lib/url';

interface Props {
  title: string;
  description: string;
  tags: string[];
  url?: string;
  repo?: string;
}

const { title, description, tags, url, repo } = Astro.props;
---

<Layout title={`${title} — Marissa Joy`} description={description}>
  <a href={`${base}projects/`} class="inline-block text-sm text-blue-500 hover:text-blue-800 transition-colors mb-8">
    ← Back to projects
  </a>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-3">{title}</h1>
      {tags.length > 0 && (
        <ul class="flex gap-2 flex-wrap mb-4">
          {tags.map(tag => (
            <li class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded">{tag}</li>
          ))}
        </ul>
      )}
      <div class="flex gap-4 text-sm">
        {url && (
          <a href={url} class="text-blue-600 hover:text-blue-800 transition-colors" target="_blank" rel="noopener noreferrer">
            Live site ↗
          </a>
        )}
        {repo && (
          <a href={repo} class="text-blue-600 hover:text-blue-800 transition-colors" target="_blank" rel="noopener noreferrer">
            Source ↗
          </a>
        )}
      </div>
    </header>
    <div class="prose prose-gray max-w-none">
      <slot />
    </div>
  </article>
</Layout>
